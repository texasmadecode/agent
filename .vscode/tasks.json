{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Marketing Agent Server",
            "type": "shell",
            "command": "source venv/bin/activate && python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
            "group": "build",
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "new",
                "showReuseMessage": true,
                "clear": false
            },
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "Install Dependencies",
            "type": "shell",
            "command": "source venv/bin/activate && pip install -r requirements-minimal.txt",
            "group": "build",
            "problemMatcher": [],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "Run Database Migration",
            "type": "shell",
            "command": "source venv/bin/activate && alembic upgrade head",
            "group": "build",
            "problemMatcher": [],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "Initialize Database",
            "type": "shell",
            "command": "source venv/bin/activate && python -m app.core.init_db",
            "group": "build",
            "problemMatcher": [],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "Test API Import",
            "type": "shell",
            "command": "source venv/bin/activate && python -c \"from app.main import app; print('FastAPI app imported successfully')\"",
            "group": "test",
            "problemMatcher": [],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        }
    ]
}